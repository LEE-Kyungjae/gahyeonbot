#!/usr/bin/env bash
set -euo pipefail

current_branch="$(git symbolic-ref --quiet --short HEAD || true)"
if [[ -z "$current_branch" ]]; then
  exit 0
fi

if [[ "${GAHYEONBOT_ALLOW_NON_DEVELOP_PUSH:-0}" != "1" && "$current_branch" != "develop" ]]; then
  if [[ "$current_branch" == "main" ]]; then
    echo "Direct pushes to 'main' are blocked locally." >&2
  else
    echo "Pushing from '$current_branch' is blocked. Push from 'develop' instead." >&2
  fi
  echo "Override once with GAHYEONBOT_ALLOW_NON_DEVELOP_PUSH=1 git push" >&2
  exit 1
fi
